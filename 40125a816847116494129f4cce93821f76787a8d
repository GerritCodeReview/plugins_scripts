    {
      "unresolved": false,
      "key": {
        "uuid": "80211d18_3a321724",
        "filename": "ai/ai-review-agent-llama-1.0.groovy",
        "patchSetId": 8
      },
      "lineNbr": 59,
      "author": {
        "id": 1006192
      },
      "writtenOn": "2026-05-15T12:53:45Z",
      "side": 1,
      "message": "No, because failing to fetch the list of models would break the UI. A provider without models won\u0027t break the UI and will not populate the models in the drop-down list. The approach is the same for all other AI LLMs API scripts.",
      "parentUuid": "a2372789_8c9aaaa5",
      "range": {
        "startLine": 59,
        "startChar": 0,
        "endLine": 59,
        "endChar": 28
      },
      "revId": "40125a816847116494129f4cce93821f76787a8d",
