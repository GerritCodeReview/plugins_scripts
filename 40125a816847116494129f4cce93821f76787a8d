        "id": 1072905
      },
      "writtenOn": "2026-05-15T07:58:32Z",
      "side": 1,
      "message": "This assumes the error message we get back is Json, which might be true for API-specific errors, If the server returns plain text, HTML, an empty body (from proxies for example), this will not be the case.\n\nThis expose a Json parsing failure to the user, which might hide the real problem.",
      "range": {
        "startLine": 101,
        "startChar": 0,
        "endLine": 101,
        "endChar": 52
      },
      "revId": "40125a816847116494129f4cce93821f76787a8d",
