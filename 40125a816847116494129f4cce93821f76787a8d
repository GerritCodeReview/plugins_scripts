      "writtenOn": "2026-05-15T07:58:32Z",
      "side": 1,
      "message": "At L77 we throw `IllegalStateException` when failing to call the API, while here we swallow the error and default to an empty set.\n\nShould we not throw here as well?",
      "range": {
        "startLine": 59,
        "startChar": 0,
        "endLine": 59,
        "endChar": 28
      },
      "revId": "40125a816847116494129f4cce93821f76787a8d",
