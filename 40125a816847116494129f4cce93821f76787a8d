    },
    {
      "unresolved": true,
      "key": {
        "uuid": "78fab718_850819b4",
        "filename": "ai/ai-review-agent-llama-1.0.groovy",
        "patchSetId": 8
      },
      "lineNbr": 101,
      "author": {
        "id": 1072905
      },
      "writtenOn": "2026-05-15T07:58:32Z",
      "side": 1,
      "message": "This assumes the error message we get back is Json, which might be true for API-specific errors, If the server returns plain text, HTML, an empty body (from proxies for example), this will not be the case.\n\nThis expose a Json parsing failure to the user, which might hide the real problem.",
      "range": {
        "startLine": 101,
        "startChar": 0,
        "endLine": 101,
        "endChar": 52
      },
      "revId": "40125a816847116494129f4cce93821f76787a8d",
      "serverId": "173816e5-2b9a-37c3-8a2e-48639d4f1153"
    },
    {
      "unresolved": false,
      "key": {
        "uuid": "cd9232a3_03705ac1",
        "filename": "ai/ai-review-agent-llama-1.0.groovy",
        "patchSetId": 8
      },
      "lineNbr": 101,
      "author": {
        "id": 1006192
      },
      "writtenOn": "2026-05-15T12:53:45Z",
      "side": 1,
      "message": "True, but we can\u0027t really account for any potential proxies that anyone could put between Gerrit and the LLM backend.\n\nThis code is for fetching the LLM errors, and that\u0027s what it does.\nIt wouldn\u0027t be realistic to account for any potential syntax in this implementation.",
      "parentUuid": "78fab718_850819b4",
      "range": {
        "startLine": 101,
        "startChar": 0,
        "endLine": 101,
        "endChar": 52
      },
      "revId": "40125a816847116494129f4cce93821f76787a8d",
      "serverId": "173816e5-2b9a-37c3-8a2e-48639d4f1153"
    },
    {
